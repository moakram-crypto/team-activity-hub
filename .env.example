# Shared password every teammate uses to log in
TEAM_PASSWORD=change-me

# Long random string used to sign session cookies
SESSION_SECRET=change-me-too

# Secret configured on the GitHub webhook (Settings > Webhooks) so we can
# verify pushes/PRs really came from GitHub
GITHUB_WEBHOOK_SECRET=change-me-as-well

# Port the server listens on (Railway sets this automatically in production)
PORT=3000
